# Copy to .streamlit/secrets.toml (gitignored). Never commit real passwords.
#
# If you use split keys here, they override a shell ``export DATABASE_URL=…``
# (so a stale direct db.*:5432 URL in the terminal does not win).
#
# =============================================================================
# Option A — Split keys (best if password has @ # :)
# =============================================================================
# Dashboard → Database → Connection string → **Transaction pooler** (or Session).
# Replace host/region/user with yours; password = Database password (not account).

# DATABASE_HOST = "aws-0-us-west-2.pooler.supabase.com"
# DATABASE_USER = "postgres.your-project-ref"
# DATABASE_PASSWORD = "your-database-password"
# DATABASE_PORT = "6543"
# DATABASE_NAME = "postgres"
# DATABASE_SSLMODE = "require"
# Port 6543 automatically adds pgbouncer=true to the URI. To force it on another
# port: DATABASE_PGBOUNCER = "true"

# =============================================================================
# Option B — Full URI (replace [YOUR-PASSWORD]; @ in password → %40)
# =============================================================================
# DATABASE_URL = "postgresql://postgres.your-ref:[YOUR-PASSWORD]@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# If sslmode is missing, the app appends sslmode=require automatically.

# =============================================================================
# Supabase Auth — required for user login
# =============================================================================
# Dashboard → Settings → API → Project URL / anon key / service_role key.
SUPABASE_URL = "https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY = "eyJ..."
SUPABASE_SERVICE_ROLE_KEY = "eyJ..."

# =============================================================================
# Auth bypass — local dev only
# =============================================================================
# AUTH_DISABLED = "true"
